---
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';
import { ui, getCanonicalPath, type Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
  /** Pass false to suppress hreflang (e.g. Impressum). */
  hreflang?: boolean;
}
const { title, description, image, type, hreflang = true } = Astro.props;

const lang = (Astro.currentLocale ?? 'de') as Lang;
const t = ui[lang];
const isRtl = lang === 'ar';
const path = Astro.url.pathname;
const canonicalPath = getCanonicalPath(path);

// Locale-specific URL helpers
const deHref = (p: string) => p;
const enHref = (p: string) => `/en${p}`;
const arHref = (p: string) => `/ar${p}`;

const navBase = canonicalPath === '/' ? '/' : canonicalPath;
const deRoot = '/';
const enRoot = '/en/';
const arRoot = '/ar/';

// Detect active section for nav highlights
const isServices = path.includes('/leistungen');
const isBlog = path.includes('/blog');
---
<!DOCTYPE html>
<html lang={lang} dir={isRtl ? 'rtl' : 'ltr'}>
<head>
  <BaseHead
    title={title}
    description={description}
    image={image}
    type={type}
    lang={lang}
    canonicalPath={hreflang ? canonicalPath : undefined}
  />
  <slot name="head" />
</head>
<body>
<a class="skip-link" href="#main-content">{t.skip}</a>
<nav aria-label={isRtl ? 'التنقل الرئيسي' : 'Hauptnavigation'}>
  <div class="nav-in">
    <a class="brand" href={lang === 'de' ? deRoot : lang === 'en' ? enRoot : arRoot}
       aria-label="Mohammad Chakrouf">
      <span class="mark" aria-hidden="true">MC</span><span>chakrouf</span>
    </a>
    <div class="nav-links">
      <a href={`${lang === 'de' ? '' : lang === 'en' ? '/en' : '/ar'}/#work`}>{t.nav.work}</a>
      <a href={`${lang === 'de' ? '' : lang === 'en' ? '/en' : '/ar'}/#approach`}>{t.nav.approach}</a>
      <a href={`${lang === 'de' ? '' : lang === 'en' ? '/en' : '/ar'}/#build`}>{t.nav.build}</a>
      <a href={`${lang === 'de' ? '' : lang === 'en' ? '/en' : '/ar'}/#about`}>{t.nav.about}</a>
      <a href={lang === 'de' ? '/#leistungen' : lang === 'en' ? '/en/#leistungen' : '/ar/#leistungen'}
         aria-current={isServices ? 'page' : undefined}>{t.nav.services}</a>
      <a href={lang === 'de' ? '/blog/' : lang === 'en' ? '/en/blog/' : '/ar/blog/'}
         aria-current={isBlog ? 'page' : undefined}>{t.nav.blog}</a>
    </div>
    <div class="nav-right">
      <div class="langtoggle" role="group" aria-label={t.langLabel}>
        <a href={deHref(navBase === '/' ? '/' : navBase)}
           class:list={['lang-btn', lang === 'de' && 'active']}
           aria-current={lang === 'de' ? 'true' : undefined}
           hreflang="de">DE</a>
        <a href={enHref(navBase)}
           class:list={['lang-btn', lang === 'en' && 'active']}
           aria-current={lang === 'en' ? 'true' : undefined}
           hreflang="en">EN</a>
        <a href={arHref(navBase)}
           class:list={['lang-btn', lang === 'ar' && 'active']}
           aria-current={lang === 'ar' ? 'true' : undefined}
           hreflang="ar">AR</a>
      </div>
      <a href="https://cal.com/mohammad-chakrouf-sp9k7e/hubspot-erstgesprach"
        class="btn btn-primary nav-cta"
        target="_blank"
        rel="noopener"
        aria-label={t.nav.ctaAriaOpen}>{t.nav.ctaLabel}</a>
    </div>
  </div>
</nav>
<main id="main-content" tabindex="-1">
  <slot />
</main>
<footer>
  <div class="wrap foot-in">
    <span>Mohammad Chakrouf · {t.footer.role}</span>
    <div style="display:flex;flex-wrap:wrap;gap:16px;align-items:center">
      <a href={lang === 'de' ? '/leistungen/hubspot-migration/' : lang === 'en' ? '/en/leistungen/hubspot-migration/' : '/ar/leistungen/hubspot-migration/'}>{t.footer.migration}</a>
      <a href={lang === 'de' ? '/leistungen/revops-fuer-startups/' : lang === 'en' ? '/en/leistungen/revops-fuer-startups/' : '/ar/leistungen/revops-fuer-startups/'}>{t.footer.revops}</a>
      <a href={lang === 'de' ? '/leistungen/hubspot-fuer-b2b-saas/' : lang === 'en' ? '/en/leistungen/hubspot-fuer-b2b-saas/' : '/ar/leistungen/hubspot-fuer-b2b-saas/'}>{t.footer.saas}</a>
      <span style="color:var(--line)" aria-hidden="true">|</span>
      <a href="/impressum/">{t.footer.impressum}</a>
      <a href="/datenschutz/">{t.footer.datenschutz}</a>
      <a href="/barrierefreiheit/">{t.footer.barrierefreiheit}</a>
    </div>
    <span>© <span id="year"></span> · {t.footer.built}</span>
  </div>
</footer>
<script is:inline>(function () {
  // Year
  var yr = document.getElementById('year');
  if (yr) yr.textContent = new Date().getFullYear();

  // Scroll-reveal
  var els = document.querySelectorAll('.reveal');
  if (!('IntersectionObserver' in window)) {
    for (var k = 0; k < els.length; k++) els[k].classList.add('in');
  } else {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    for (var m = 0; m < els.length; m++) io.observe(els[m]);
  }
})();</script>
</body>
</html>
