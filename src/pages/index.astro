        <div class="record-rows" style="padding-top:10px">
          <div class="row"><span class="k" data-de="Erfahrung" data-en="Experience">Erfahrung</span><span class="v" data-de="6 Jahre HubSpot" data-en="6 years HubSpot">6 Jahre HubSpot</span></div>
          <div class="row"><span class="k">Hubs</span><span class="v">Marketing · Sales · Service · Ops</span></div>
          <div class="row"><span class="k">Engineering</span><span class="v">React · Node.js · HubSpot CLI</span></div>
          <div class="row"><span class="k" data-de="Modell" data-en="Model">Modell</span><span class="v" data-de="Projekt · Mandat · Subcontracting" data-en="Project · Retainer · Subcontracting">Projekt · Mandat · Subcontracting</span></div>
          <div class="row"><span class="k" data-de="Region" data-en="Region">Region</span><span class="v">DACH · Remote</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="block" style="border-top:1px solid var(--line);padding:56px 0">
  <div class="wrap">
    <p class="eyebrow" data-de="Leistungen" data-en="Services">Leistungen</p>
    <div class="work-grid" style="grid-template-columns:repeat(auto-fit,minmax(260px,1fr));margin-top:28px">
