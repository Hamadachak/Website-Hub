---
import Base from "../layouts/Base.astro";
const professionalServiceLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Mohammad Chakrouf — HubSpot Consultant Berlin",
  "description": "Freelance Senior HubSpot Berater in Berlin. CRM-Architektur, Datenmigration und RevOps für B2B-Unternehmen im DACH-Raum.",
  "url": "https://mohammad-chakrouf.de",
  "address": { "@type": "PostalAddress", "addressLocality": "Berlin", "addressCountry": "DE" },
  "areaServed": [
    { "@type": "Country", "name": "Germany" },
    { "@type": "Country", "name": "Austria" },
    { "@type": "Country", "name": "Switzerland" }
  ],
  "knowsAbout": ["HubSpot","CRM","Revenue Operations","Datenmigration","Marketing Automation"]
};
---
<Base
  title="HubSpot Consultant Berlin – CRM, RevOps & Datenmigration | Mohammad Chakrouf"
  titleEn="HubSpot Consultant Berlin – CRM, RevOps & Data Migration | Mohammad Chakrouf"
  description="Freelance Senior HubSpot Berater in Berlin. CRM-Architektur, Datenmigration und RevOps für B2B-Unternehmen und Agenturen im DACH-Raum."
  descriptionEn="Freelance Senior HubSpot consultant in Berlin. CRM architecture, data migration and RevOps for B2B companies across the DACH region."
>
<script slot="head" type="application/ld+json" set:html={JSON.stringify(professionalServiceLd)} />
<header class="hero" id="top">
  <div class="wrap">
    <div class="hero-grid">
      <div>
        <p class="eyebrow"><span class="b">Freelance</span> · Berlin · HubSpot &amp; RevOps</p>
        <h1 data-de="Aus chaotischem HubSpot wird ein System, dem das Team vertraut." data-en="I turn HubSpot into the system you were promised.">Aus chaotischem HubSpot wird ein System, dem das Team vertraut.</h1>
        <p class="sub" data-de="HubSpot Berater und Freelancer in Berlin. Ich entwerfe CRM-Architekturen, migriere Daten ohne Chaos und automatisiere Prozesse über Marketing, Sales und Service hinweg — und baue eigene Tools, wenn der Standard nicht reicht." data-en="Freelance HubSpot consultant in Berlin. I design CRM architecture, migrate data without the chaos, and automate across Marketing, Sales and Service — and build custom tooling when the standard product runs out.">HubSpot Berater und Freelancer in Berlin. Ich entwerfe CRM-Architekturen, migriere Daten ohne Chaos und automatisiere Prozesse über Marketing, Sales und Service hinweg — und baue eigene Tools, wenn der Standard nicht reicht.</p>
        <div class="hero-actions">
          <a href="#contact" class="btn btn-primary" data-de="Kontakt aufnehmen" data-en="Get in touch">Kontakt aufnehmen</a>
          <a href="#work" class="btn btn-ghost" data-de="Projekte ansehen" data-en="See the work">Projekte ansehen</a>
        </div>
        <p class="status"><span class="dot"></span><span data-de="Verfügbar für Projekte · 3 Tage / Woche" data-en="Available for projects · 3 days / week">Verfügbar für Projekte · 3 Tage / Woche</span></p>
      </div>

      <div class="record reveal">
        <div class="record-tab">// <span data-de="Datensatz" data-en="Contact record">Datensatz</span></div>
        <div class="record-head">
          <div class="avatar">MC</div>
          <div>
            <div class="name">Mohammad Chakrouf</div>
            <div class="role">Senior HubSpot Consultant</div>
          </div>
        </div>
        <div class="record-rows">
          <div class="row"><span class="k" data-de="Rolle" data-en="Role">Rolle</span><span class="v">CRM Architect · RevOps</span></div>
          <div class="row"><span class="k" data-de="Standort" data-en="Location">Standort</span><span class="v" data-de="Berlin · Remote (DACH)" data-en="Berlin · Remote (DACH)">Berlin · Remote (DACH)</span></div>
          <div class="row"><span class="k" data-de="Erfahrung" data-en="Experience">Erfahrung</span><span class="v" data-de="6 Jahre · alle Hubs" data-en="6 years · all Hubs">6 Jahre · alle Hubs</span></div>
          <div class="row"><span class="k" data-de="Fokus" data-en="Focus">Fokus</span><span class="v" data-de="Architektur · Migration · Automation" data-en="Architecture · Migration · Automation">Architektur · Migration · Automation</span></div>
          <div class="row"><span class="k">Stack</span><span class="v">HubSpot CLI · React · Node.js</span></div>
          <div class="row"><span class="k" data-de="Sprachen" data-en="Languages">Sprachen</span><span class="v">Deutsch · English</span></div>
          <div class="row"><span class="k">Status</span><span class="v"><span class="mini-dot"></span><span data-de="Verfügbar" data-en="Available">Verfügbar</span></span></div>
        </div>
      </div>
    </div>
  </div>
</header>

<div class="caps">
  <div class="wrap caps-in">
    <span class="tag" data-de="Objektmodellierung" data-en="Object modeling">Objektmodellierung</span>
    <span class="tag" data-de="Datenmigration" data-en="Data migration">Datenmigration</span>
    <span class="tag" data-de="Workflow-Automatisierung" data-en="Workflow automation">Workflow-Automatisierung</span>
    <span class="tag">Reporting &amp; Dashboards</span>
    <span class="tag" data-de="Integrationen" data-en="Integrations">Integrationen</span>
    <span class="tag">Custom UI Extensions</span>
    <span class="tag" data-de="Lifecycle &amp; Pipelines" data-en="Lifecycle &amp; Pipelines">Lifecycle &amp; Pipelines</span>
    <span class="tag" data-de="Datenhygiene" data-en="Data governance">Datenhygiene</span>
  </div>
</div>

<section class="block" id="work">
  <div class="wrap">
    <div class="head reveal">
      <p class="eyebrow" data-de="Ausgewählte Projekte" data-en="Selected work">Ausgewählte Projekte</p>
      <h2 data-de="Aufräumen, neu bauen, zum Laufen bringen." data-en="Clean it up, rebuild it, make it run.">Aufräumen, neu bauen, zum Laufen bringen.</h2>
    </div>
    <div class="work-grid">
      <article class="case reveal">
        <span class="ctag" data-de="B2B · Merger · ~130 Mitarbeitende" data-en="B2B · Merger · ~130 employees">B2B · Merger · ~130 Mitarbeitende</span>
        <h3 data-de="Fünf Firmen, ein CRM" data-en="Five companies, one CRM">Fünf Firmen, ein CRM</h3>
        <p data-de="Konsolidierung von fünf fusionierten Unternehmen auf einen HubSpot-Account. Objektmodell von Grund auf neu entworfen, Daten aus mehreren Altsystemen migriert, eine gemeinsame Pipeline-Strategie definiert und in Phasen ausgerollt — ohne den laufenden Betrieb zu unterbrechen." data-en="Consolidated five merged companies onto a single HubSpot account. Designed the object model from scratch, migrated data from multiple legacy systems, defined one shared pipeline strategy, and rolled it out in phases — without interrupting day-to-day operations.">Konsolidierung von fünf fusionierten Unternehmen auf einen HubSpot-Account. Objektmodell von Grund auf neu entworfen, Daten aus mehreren Altsystemen migriert, eine gemeinsame Pipeline-Strategie definiert und in Phasen ausgerollt — ohne den laufenden Betrieb zu unterbrechen.</p>
        <p class="outcome"><b data-de="Ergebnis" data-en="Outcome">Ergebnis</b> · <span data-de="Ein einheitliches Datenmodell und eine Pipeline aus 5 Altsystemen, live für ~130 Nutzer." data-en="One unified data model and pipeline out of 5 legacy systems, live for ~130 users.">Ein einheitliches Datenmodell und eine Pipeline aus 5 Altsystemen, live für ~130 Nutzer.</span></p>
      </article>

      <article class="case reveal">
        <span class="ctag" data-de="B2B SaaS · Laufend" data-en="B2B SaaS · Ongoing">B2B SaaS · Laufend</span>
        <h3 data-de="CRM-Restrukturierung im Wachstum" data-en="Restructuring a CRM mid-scale">CRM-Restrukturierung im Wachstum</h3>
        <p data-de="Laufendes Mandat (3 Tage / Woche): Ein organisch gewachsenes HubSpot-Setup wird aufgeräumt und neu strukturiert. Properties, Lifecycle-Stages und Automatisierungen werden neu geordnet, damit Reporting wieder verlässlich ist und das Team dem System vertraut." data-en="Current engagement (3 days / week): cleaning up and restructuring a HubSpot setup that grew organically. Re-ordering properties, lifecycle stages and automations so reporting is trustworthy again and the team trusts the system.">Laufendes Mandat (3 Tage / Woche): Ein organisch gewachsenes HubSpot-Setup wird aufgeräumt und neu strukturiert. Properties, Lifecycle-Stages und Automatisierungen werden neu geordnet, damit Reporting wieder verlässlich ist und das Team dem System vertraut.</p>
        <p class="outcome"><b data-de="Schwerpunkt" data-en="Focus">Schwerpunkt</b> · <span data-de="Datenhygiene, sauberes Lifecycle-Modell, verlässliches Reporting." data-en="Data hygiene, a clean lifecycle model, reporting you can trust.">Datenhygiene, sauberes Lifecycle-Modell, verlässliches Reporting.</span></p>
      </article>

      <article class="case reveal">
        <span class="ctag">PropTech · Berlin</span>
        <h3 data-de="Ticketsystem mit Rotationslogik" data-en="A ticketing system with rotation logic">Ticketsystem mit Rotationslogik</h3>
        <p data-de="Für ein Berliner Property-Management-Unternehmen ein vollständiges Ticketsystem in HubSpot gebaut — inklusive Pipeline-Logik und automatischer Zuweisung im Rotationsverfahren, damit Anfragen fair und nachvollziehbar verteilt werden." data-en="Built a full ticketing system in HubSpot for a Berlin property-management company — pipeline logic plus automatic round-robin assignment, so requests are distributed fairly and transparently.">Für ein Berliner Property-Management-Unternehmen ein vollständiges Ticketsystem in HubSpot gebaut — inklusive Pipeline-Logik und automatischer Zuweisung im Rotationsverfahren, damit Anfragen fair und nachvollziehbar verteilt werden.</p>
        <p class="outcome"><b data-de="Ergebnis" data-en="Outcome">Ergebnis</b> · <span data-de="Strukturierter Support-Flow mit automatischer, fairer Lastverteilung." data-en="A structured support flow with automatic, fair load distribution.">Strukturierter Support-Flow mit automatischer, fairer Lastverteilung.</span></p>
      </article>
    </div>
  </div>
</section>

<section class="block" id="approach" style="border-top:1px solid var(--line)">
  <div class="wrap">
    <div class="head reveal">
      <p class="eyebrow" data-de="So arbeite ich" data-en="How I work">So arbeite ich</p>
      <h2 data-de="Eine Pipeline — von kaputt zu verlässlich." data-en="One pipeline — from broken to dependable.">Eine Pipeline — von kaputt zu verlässlich.</h2>
    </div>
    <div class="pipe reveal">
      <div class="stage">
        <div class="num">01</div>
        <h3 data-de="Discovery" data-en="Discovery">Discovery</h3>
        <p data-de="Verstehen, was kaputt ist. Audit von Daten, Prozessen und warum das Reporting lügt." data-en="Understand what's broken. Audit of data, processes, and why the reporting lies.">Verstehen, was kaputt ist. Audit von Daten, Prozessen und warum das Reporting lügt.</p>
      </div>
      <div class="stage">
        <div class="num">02</div>
        <h3 data-de="Architektur" data-en="Architecture">Architektur</h3>
        <p data-de="Objekt- und Datenmodell entwerfen, das auch in zwei Jahren noch trägt." data-en="Design an object and data model that still holds in two years.">Objekt- und Datenmodell entwerfen, das auch in zwei Jahren noch trägt.</p>
      </div>
      <div class="stage">
        <div class="num">03</div>
        <h3 data-de="Migration" data-en="Migration">Migration</h3>
        <p data-de="Daten sauber überführen — ohne Dubletten, ohne verwaiste Datensätze." data-en="Move data cleanly — no duplicates, no orphaned records.">Daten sauber überführen — ohne Dubletten, ohne verwaiste Datensätze.</p>
      </div>
      <div class="stage">
        <div class="num">04</div>
        <h3 data-de="Automation" data-en="Automation">Automation</h3>
        <p data-de="Prozesse in verlässliche Workflows gießen, die das Team nicht umgeht." data-en="Turn processes into reliable workflows the team won't route around.">Prozesse in verlässliche Workflows gießen, die das Team nicht umgeht.</p>
      </div>
      <div class="stage">
        <div class="num">05</div>
        <h3 data-de="Enablement" data-en="Enablement">Enablement</h3>
        <p data-de="Das Team befähigen statt abhängig machen. Übergabe, Doku, Schulung." data-en="Enable the team instead of creating dependency. Handover, docs, training.">Das Team befähigen statt abhängig machen. Übergabe, Doku, Schulung.</p>
      </div>
    </div>
  </div>
</section>

<section class="block" id="build" style="border-top:1px solid var(--line)">
