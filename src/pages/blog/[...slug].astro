---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";
import { marked } from "marked";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) => d.toLocaleDateString("de-DE", { year: "numeric", month: "long", day: "numeric" });
const bodyEnHtml = post.data.bodyEn ? marked.parse(post.data.bodyEn) : null;
---
<Base
  title={`${post.data.title} — Mohammad Chakrouf`}
  titleEn={post.data.titleEn ? `${post.data.titleEn} — Mohammad Chakrouf` : undefined}
  description={post.data.description}
  descriptionEn={post.data.descriptionEn}
  image={post.data.heroImage}
  type="article"
>
  <article class="block">
    <div class="wrap" style="max-width:760px">

      <p class="eyebrow">{fmt(post.data.pubDate)}</p>

      {post.data.heroImage && (
        <img
          src={post.data.heroImage}
          alt={post.data.title}
          width="760"
          height="399"
          loading="eager"
          style="width:100%;height:auto;border-radius:12px;margin:24px 0 32px;border:1px solid var(--line);display:block"
        />
      )}

      <h1
        data-de={post.data.title}
        data-en={post.data.titleEn ?? post.data.title}
        style="font-family:var(--display);font-weight:900;font-size:clamp(2rem,5vw,3rem);line-height:1.08;letter-spacing:-.02em;margin:0 0 32px"
      >{post.data.title}</h1>

      {/* German body — rendered by Astro from the .md file */}
      <div class="prose" data-lang-block="de">
        <Content />
      </div>

      {/* English body — rendered from the bodyEn frontmatter field via marked */}
      {bodyEnHtml && (
        <div class="prose" data-lang-block="en" style="display:none" set:html={bodyEnHtml} />
      )}

      {/* In-content visuals (SVG cards generated by the pipeline) */}
      {post.data.visuals && post.data.visuals.length > 0 && (
        <div style="margin:40px 0 8px">
          {post.data.visuals.map((src) => (
            <img
              src={src}
              alt="Key Takeaways"
              width="700"
              height="200"
              loading="lazy"
              style="width:100%;max-width:700px;height:auto;display:block;margin:0 0 16px"
            />
          ))}
        </div>
      )}

      {/* Source attribution */}
      {post.data.sourceUrl && (
        <p style="margin-top:36px;padding-top:20px;border-top:1px solid var(--line);font-family:var(--mono);font-size:.78rem;color:var(--muted)">
          <span data-de="Quelle" data-en="Source">Quelle</span>:&nbsp;
          <a
            href={post.data.sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${post.data.sourceTitle || post.data.sourceUrl} (öffnet in neuem Tab)`}
            style="color:var(--amber);text-decoration:underline;text-underline-offset:3px"
          >{post.data.sourceTitle || post.data.sourceUrl}</a>
        </p>
      )}

      <p style="margin-top:44px"><a href="/blog/" class="btn btn-ghost" data-de="← Alle Beiträge" data-en="← All posts">← Alle Beiträge</a></p>

      <div style="margin-top:56px;padding-top:32px;border-top:1px solid var(--line)">
        <p class="eyebrow" data-de="Passende Leistungen" data-en="Related services">Passende Leistungen</p>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;margin-top:20px">
          <a class="case" href="/leistungen/hubspot-migration" style="text-decoration:none;display:block;padding:20px 22px">
            <span class="ctag" data-de="Migration" data-en="Migration">Migration</span>
            <h3 style="font-size:1rem;margin:10px 0 8px" data-de="HubSpot-Migration" data-en="HubSpot Migration">HubSpot-Migration</h3>
            <p style="font-size:.88rem" data-de="Sauber migriert, kein Chaos." data-en="Clean migration, no chaos.">Sauber migriert, kein Chaos.</p>
          </a>
          <a class="case" href="/leistungen/revops-fuer-startups" style="text-decoration:none;display:block;padding:20px 22px">
            <span class="ctag">RevOps</span>
            <h3 style="font-size:1rem;margin:10px 0 8px" data-de="RevOps für Startups" data-en="RevOps for Startups">RevOps für Startups</h3>
            <p style="font-size:.88rem" data-de="Eine Datenbasis für alle Teams." data-en="One data foundation for all teams.">Eine Datenbasis für alle Teams.</p>
          </a>
          <a class="case" href="/leistungen/hubspot-fuer-b2b-saas" style="text-decoration:none;display:block;padding:20px 22px">
            <span class="ctag">B2B SaaS</span>
            <h3 style="font-size:1rem;margin:10px 0 8px" data-de="HubSpot für B2B-SaaS" data-en="HubSpot for B2B SaaS">HubSpot für B2B-SaaS</h3>
            <p style="font-size:.88rem" data-de="PQL, Trial-Flows, Churn-Signale." data-en="PQL, trial flows, churn signals.">PQL, Trial-Flows, Churn-Signale.</p>
          </a>
        </div>
      </div>
    </div>
  </article>
</Base>
