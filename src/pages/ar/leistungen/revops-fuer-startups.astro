---
import Base from "../../../layouts/Base.astro";
const serviceLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "RevOps للشركات الناشئة",
  "description": "عمليات الإيرادات للشركات الناشئة النامية: التسويق والمبيعات والخدمة على قاعدة بيانات واحدة لتقارير موثوقة ونمو قابل للتوسع.",
  "provider": { "@id": "https://mohammad-chakrouf.de/#person" },
  "areaServed": [
    { "@type": "Country", "name": "Germany" },
    { "@type": "Country", "name": "United Arab Emirates" },
    { "@type": "Country", "name": "Saudi Arabia" }
  ],
  "serviceType": "Revenue Operations Consulting"
};
---
<Base
  title="RevOps للشركات الناشئة — محمد شكروف، مستشار HubSpot في برلين"
  description="عمليات الإيرادات للشركات الناشئة النامية: التسويق والمبيعات والخدمة على قاعدة بيانات واحدة — لتقارير موثوقة ونمو قابل للتوسع."
>
<script slot="head" type="application/ld+json" set:html={JSON.stringify(serviceLd)} />

<header class="hero" id="top">
  <div class="wrap">
    <p class="eyebrow"><span class="b">خدمة</span> · RevOps للشركات الناشئة</p>
    <h1 style="font-family:var(--display);font-weight:900;font-size:clamp(2.4rem,5.5vw,4rem);line-height:1.05;letter-spacing:-.025em;max-width:16ch;margin:20px 0 22px">التسويق والمبيعات والخدمة — أخيراً على قاعدة بيانات واحدة.</h1>
    <p class="sub" style="max-width:50ch">أبني أساس RevOps حتى يتوقف فريقك عن سحب الأرقام من ثلاثة مصادر مختلفة — ويبدأ باتخاذ قرارات مبنية على بيانات موثوقة.</p>
    <div class="hero-actions" style="margin-top:28px">
      <a href="/ar/#contact" class="btn btn-primary">طلب استشارة</a>
      <a href="/ar/#about" class="btn btn-ghost">نبذة عني</a>
    </div>
  </div>
</header>

<div class="caps">
  <div class="wrap caps-in">
    <span class="tag">نموذج دورة الحياة</span>
    <span class="tag">توجيه العملاء المحتملين</span>
    <span class="tag">تصميم المسار</span>
    <span class="tag">الإسناد</span>
    <span class="tag">التقارير ولوحات البيانات</span>
    <span class="tag">جودة CRM</span>
    <span class="tag">توافق GTM</span>
    <span class="tag">مراجعة مكدس الأدوات</span>
  </div>
</div>

<section class="block" id="leistung">
  <div class="wrap">
    <div class="head reveal">
      <p class="eyebrow">ما يعنيه RevOps فعلياً</p>
      <h2>ليس مجرد مفهوم. أساس عملي فعّال.</h2>
    </div>
    <div class="work-grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr))">
      <div class="case reveal">
        <span class="ctag">Unified Data Model</span>
        <h3>نموذج كائن واحد لجميع الفرق</h3>
        <p>جهة اتصال، شركة، صفقة، تذكرة — محددة بوضوح ومملوءة باتساق. لا تضخم في الخصائص، لا تسليم يدوي بين الأقسام.</p>
      </div>
      <div class="case reveal">
        <span class="ctag">Lifecycle &amp; Pipeline</span>
        <h3>مراحل دورة حياة تُدار ذاتياً</h3>
        <p>انتقالات تلقائية بين المراحل بناءً على معايير واضحة — بدلاً من الانضباط اليدوي الذي ينهار بعد ثلاثة أسابيع.</p>
      </div>
      <div class="case reveal">
        <span class="ctag">Reporting</span>
        <h3>لوحات بيانات يثق بها الفريق</h3>
        <p>MQL وSQL ومعدل الفوز والإلغاء — من مصدر واحد لا ثلاثة جداول. أبني لوحات بيانات يستخدمها فريقك يومياً.</p>
      </div>
      <div class="case reveal">
        <span class="ctag">تصميم العمليات</span>
        <h3>منطق توجيه العملاء المحتملين والتسليم</h3>
        <p>متى ينتقل العميل المحتمل من التسويق إلى المبيعات، وكيف تُصعَّد الصفقات، وكيف يُبلَّغ فريق خدمة العملاء — كأتمتة موثوقة لا سلسلة بريد إلكتروني.</p>
      </div>
    </div>
  </div>
</section>

<section class="block" style="border-top:1px solid var(--line)">
  <div class="wrap">
    <div class="head reveal">
      <p class="eyebrow">منهجية العمل</p>
      <h2>من التشخيص إلى الأساس العامل.</h2>
    </div>
    <div class="pipe reveal">
      <div class="stage">
        <div class="num">01</div>
        <h3>مراجعة GTM</h3>
        <p>كيف يتعاون التسويق والمبيعات والخدمة اليوم؟ أين تنشأ الاحتكاكات وفقدان البيانات والنقاط العمياء في القمع؟</p>
      </div>
      <div class="stage">
        <div class="num">02</div>
        <h3>تصميم النموذج</h3>
        <p>تصميم الكائنات والخصائص ومراحل دورة الحياة والمسارات لتعكس العمليات الفعلية — وتتوسع معها.</p>
      </div>
      <div class="stage">
        <div class="num">03</div>
        <h3>التنفيذ</h3>
        <p>الإعداد في HubSpot: سير العمل والتسجيل والتوجيه ولوحات البيانات. خطوة بخطوة، مع الفريق لا بدونه.</p>
      </div>
      <div class="stage">
        <div class="num">04</div>
        <h3>التسليم</h3>
        <p>التوثيق والتدريب والمسؤوليات الواضحة. الهدف هو الاستقلالية — لا الاعتماد الدائم على المستشار.</p>
      </div>
    </div>
  </div>
</section>

<section class="block" style="border-top:1px solid var(--line)">
  <div class="wrap">
    <div class="head reveal">
      <p class="eyebrow">خدمات أخرى</p>
      <h2>ماذا أقدم أيضاً.</h2>
    </div>
    <div class="work-grid" style="grid-template-columns:repeat(auto-fit,minmax(260px,1fr))">
      <a class="case" href="/ar/leistungen/hubspot-migration/" style="text-decoration:none;display:block">
        <span class="ctag">هجرة</span>
        <h3>هجرة HubSpot</h3>
        <p>من Salesforce أو Pipedrive أو Excel إلى HubSpot — منظمة ونظيفة بدون انقطاع في العمليات.</p>
      </a>
      <a class="case" href="/ar/leistungen/hubspot-fuer-b2b-saas/" style="text-decoration:none;display:block">
        <span class="ctag">B2B SaaS</span>
        <h3>HubSpot لـ B2B SaaS</h3>
        <p>تسجيل PQL، تدفقات التجربة، إشارات الإلغاء — HubSpot كمحرك نمو لشركات البرمجيات.</p>
      </a>
    </div>
  </div>
</section>

<section class="block contact" style="position:relative;border-top:1px solid var(--line)">
  <div class="wrap">
    <p class="eyebrow">التواصل</p>
    <h2>تحدي RevOps في شركتك الناشئة؟</h2>
    <p class="sub">أخبرني أين تتعثر الأمور — التقارير، التسليم، جودة المسار — وسأريك كيف يمكننا هيكلتها.</p>
    <div class="contact-actions">
      <a href="https://cal.com/mohammad-chakrouf-sp9k7e/hubspot-erstgesprach"
        class="btn btn-primary"
        target="_blank"
        rel="noopener"
        aria-label="احجز مكالمة (يفتح في نافذة جديدة)">احجز مكالمة</a>
      <a href="mailto:chakroufmohammad@gmail.com" class="btn btn-ghost">أرسل بريداً إلكترونياً</a>
      <a href="https://www.linkedin.com/in/mohammad-chakrouf-ba2818208/"
        class="btn btn-ghost"
        target="_blank"
        rel="noopener"
        aria-label="LinkedIn (يفتح في نافذة جديدة)">LinkedIn</a>
    </div>
  </div>
</section>

</Base>
