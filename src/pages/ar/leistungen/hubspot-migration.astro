---
import Base from "../../../layouts/Base.astro";
const serviceLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "هجرة HubSpot",
  "description": "هجرة بيانات إلى HubSpot: منظمة ونظيفة دون انقطاع في العمليات. من Salesforce أو Pipedrive أو Excel.",
  "provider": { "@id": "https://mohammad-chakrouf.de/#person" },
  "areaServed": [
    { "@type": "Country", "name": "Germany" },
    { "@type": "Country", "name": "United Arab Emirates" },
    { "@type": "Country", "name": "Saudi Arabia" }
  ],
  "serviceType": "CRM Migration Consulting"
};
---
<Base
  title="هجرة HubSpot — محمد شكروف، مستشار HubSpot في برلين"
  description="هجرة بيانات إلى HubSpot: منظمة ونظيفة دون انقطاع في العمليات. مستشار HubSpot أول في برلين لشركات DACH والشرق الأوسط."
>
<script slot="head" type="application/ld+json" set:html={JSON.stringify(serviceLd)} />

<header class="hero" id="top">
  <div class="wrap">
    <p class="eyebrow"><span class="b">خدمة</span> · هجرة HubSpot</p>
    <h1 style="font-family:var(--display);font-weight:900;font-size:clamp(2.4rem,5.5vw,4rem);line-height:1.05;letter-spacing:-.025em;max-width:16ch;margin:20px 0 22px">من نظام CRM القديم إلى HubSpot — بدون فوضى في البيانات.</h1>
    <p class="sub" style="max-width:50ch">أنقل جهات الاتصال والصفقات والبيانات التاريخية بشكل نظيف ومنظم — حتى تتمكن الفرقة من العمل في النظام الجديد فور الإطلاق.</p>
    <div class="hero-actions" style="margin-top:28px">
      <a href="/ar/#contact" class="btn btn-primary">ناقش المشروع</a>
      <a href="/ar/#work" class="btn btn-ghost">استعرض المشاريع</a>
    </div>
  </div>
</header>

<div class="caps">
  <div class="wrap caps-in">
    <span class="tag">Salesforce → HubSpot</span>
    <span class="tag">Pipedrive → HubSpot</span>
    <span class="tag">Excel / Sheets</span>
    <span class="tag">رسم خرائط البيانات</span>
    <span class="tag">إزالة التكرار</span>
    <span class="tag">جودة البيانات</span>
    <span class="tag">التحقق</span>
    <span class="tag">خطة التراجع</span>
  </div>
</div>

<section class="block" id="leistung">
  <div class="wrap">
    <div class="head reveal">
      <p class="eyebrow">ما أقدمه</p>
      <h2>هجرة بلا مفاجآت سيئة.</h2>
    </div>
    <div class="work-grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr))">
      <div class="case reveal">
        <span class="ctag">01</span>
        <h3>مراجعة البيانات ورسم الخرائط</h3>
        <p>أحلل بيانات المصدر — الخصائص والكائنات والعلاقات — وأصمم النموذج المستهدف في HubSpot. بلا مفاجآت بعد الاستيراد.</p>
      </div>
      <div class="case reveal">
        <span class="ctag">02</span>
        <h3>التنظيف قبل الاستيراد</h3>
        <p>دمج المكررات، تنظيف الحقول القديمة، توحيد القيم غير المتسقة. البيانات المتسخة لا تنتقل إلى النظام الجديد.</p>
      </div>
      <div class="case reveal">
        <span class="ctag">03</span>
        <h3>الهجرة التدريجية</h3>
        <p>البيئة التجريبية أولاً، ثم التحقق، ثم الإنتاج. مع خيار التراجع — حتى لا يعني أي خطأ توقف العمليات.</p>
      </div>
      <div class="case reveal">
        <span class="ctag">04</span>
        <h3>القبول والتسليم</h3>
        <p>فحص عينات، مراجعة الاكتمال، توثيق القرارات. يتسلّم الفريق نظاماً يفهمه.</p>
      </div>
    </div>
  </div>
</section>

<section class="block" style="border-top:1px solid var(--line)">
  <div class="wrap">
    <div class="head reveal">
      <p class="eyebrow">نقاط الانطلاق الشائعة</p>
      <h2>متى تكون الهجرة النظيفة حاسمة.</h2>
    </div>
    <div class="ext-grid reveal">
      <div class="ext">
        <div class="ehead"><div class="glyph" aria-hidden="true">↗</div><h3>الانتقال من Salesforce أو Pipedrive</h3></div>
        <p>الصفقات والجهات وسجلات الأنشطة التاريخية تحتاج نقلاً منظماً — بدون فقدان بيانات وبدون أسابيع من العمل اليدوي.</p>
      </div>
      <div class="ext">
        <div class="ehead"><div class="glyph" aria-hidden="true">⊞</div><h3>الاندماج والتوحيد</h3></div>
        <p>حسابات CRM متعددة تجتمع في حساب واحد. يجب أن يكون نموذج البيانات صحيحاً من البداية حتى لا تكذب التقارير فوراً.</p>
      </div>
      <div class="ext">
        <div class="ehead"><div class="glyph" aria-hidden="true">▦</div><h3>Excel / Sheets بديلاً عن CRM</h3></div>
        <p>عندما تتجاوز الشركة مرحلة جداول البيانات، يكون الاستيراد الأول هو الأهم. أحرص على أن يكون آخر تصدير يدوي.</p>
      </div>
      <div class="ext">
        <div class="ehead"><div class="glyph" aria-hidden="true">◎</div><h3>إعادة هيكلة HubSpot</h3></div>
        <p>أحياناً الهدف ليس نظاماً جديداً بل نظاماً نظيفاً: إعادة ترتيب الخصائص، توحيد الكائنات، حذف الموروثات.</p>
      </div>
    </div>
  </div>
</section>

<section class="block" style="border-top:1px solid var(--line)">
  <div class="wrap">
    <div class="head reveal">
      <p class="eyebrow">خدمات أخرى</p>
      <h2>ماذا أقدم أيضاً.</h2>
    </div>
    <div class="work-grid" style="grid-template-columns:repeat(auto-fit,minmax(260px,1fr))">
      <a class="case" href="/ar/leistungen/revops-fuer-startups/" style="text-decoration:none;display:block">
        <span class="ctag">RevOps</span>
        <h3>RevOps للشركات الناشئة</h3>
        <p>التسويق والمبيعات والخدمة على قاعدة بيانات واحدة — لتقارير موثوقة ونمو قابل للتوسع.</p>
      </a>
      <a class="case" href="/ar/leistungen/hubspot-fuer-b2b-saas/" style="text-decoration:none;display:block">
        <span class="ctag">B2B SaaS</span>
        <h3>HubSpot لـ B2B SaaS</h3>
        <p>تسجيل PQL، تدفقات التجربة، إشارات الإلغاء — HubSpot كمحرك نمو لشركات البرمجيات.</p>
      </a>
    </div>
  </div>
</section>

<section class="block contact" style="position:relative;border-top:1px solid var(--line)">
  <div class="wrap">
    <p class="eyebrow">التواصل</p>
    <h2>هل تريد مناقشة مشروع هجرة؟</h2>
    <p class="sub">أخبرني باختصار عمّا تحتاج هجرته ومن أين تأتي البيانات — وسأقيّم حجم الجهد المطلوب بواقعية.</p>
    <div class="contact-actions">
      <a href="https://cal.com/mohammad-chakrouf-sp9k7e/hubspot-erstgesprach"
        class="btn btn-primary"
        target="_blank"
        rel="noopener"
        aria-label="احجز مكالمة (يفتح في نافذة جديدة)">احجز مكالمة</a>
      <a href="mailto:chakroufmohammad@gmail.com" class="btn btn-ghost">أرسل بريداً إلكترونياً</a>
      <a href="https://www.linkedin.com/in/mohammad-chakrouf-ba2818208/"
        class="btn btn-ghost"
        target="_blank"
        rel="noopener"
        aria-label="LinkedIn (يفتح في نافذة جديدة)">LinkedIn</a>
    </div>
  </div>
</section>

</Base>
