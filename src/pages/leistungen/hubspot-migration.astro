---
import Base from "../../layouts/Base.astro";
const serviceLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "HubSpot-Migration",
  "description": "Datenmigration zu HubSpot: strukturiert, bereinigt und ohne Unterbrechung des Betriebs. Von Salesforce, Pipedrive oder Excel.",
  "provider": { "@id": "https://mohammad-chakrouf.de/#person" },
  "areaServed": [
    { "@type": "Country", "name": "Germany" },
    { "@type": "Country", "name": "Austria" },
    { "@type": "Country", "name": "Switzerland" }
  ],
  "serviceType": "CRM Migration Consulting"
};
---
<Base
  title="HubSpot-Migration — Mohammad Chakrouf, HubSpot Berater Berlin"
  titleEn="HubSpot Migration — Mohammad Chakrouf, HubSpot Consultant Berlin"
  description="Datenmigration zu HubSpot: strukturiert, bereinigt und ohne Unterbrechung des Betriebs. Senior HubSpot Berater in Berlin für DACH-Unternehmen."
  descriptionEn="HubSpot data migration: structured, clean, and without disrupting operations. Senior HubSpot consultant in Berlin for DACH companies."
>
<script slot="head" type="application/ld+json" set:html={JSON.stringify(serviceLd)} />

<header class="hero" id="top">
  <div class="wrap">
    <p class="eyebrow"><span class="b" data-de="Leistung" data-en="Service">Leistung</span><span data-de=" · HubSpot-Migration" data-en=" · HubSpot Migration"> · HubSpot-Migration</span></p>
    <h1 style="font-family:var(--display);font-weight:900;font-size:clamp(2.4rem,5.5vw,4rem);line-height:1.05;letter-spacing:-.025em;max-width:16ch;margin:20px 0 22px" data-de="Von Ihrem alten CRM zu HubSpot — ohne Datenchaos." data-en="From your old CRM to HubSpot — without data chaos.">Von Ihrem alten CRM zu HubSpot — ohne Datenchaos.</h1>
    <p class="sub" style="max-width:50ch" data-de="Ich migriere Ihre Kontakte, Deals und historischen Daten sauber, bereinigt und strukturiert — so dass das Team nach Go-live sofort im neuen System arbeiten kann." data-en="I migrate your contacts, deals, and historical data cleanly, deduplicated, and structured — so your team can work in the new system right after go-live.">Ich migriere Ihre Kontakte, Deals und historischen Daten sauber, bereinigt und strukturiert — so dass das Team nach Go-live sofort im neuen System arbeiten kann.</p>
    <div class="hero-actions" style="margin-top:28px">
      <a href="/#contact" class="btn btn-primary" data-de="Projekt besprechen" data-en="Discuss project">Projekt besprechen</a>
      <a href="/#work" class="btn btn-ghost" data-de="Referenzprojekte ansehen" data-en="View case studies">Referenzprojekte ansehen</a>
    </div>
  </div>
</header>

<div class="caps">
  <div class="wrap caps-in">
    <span class="tag">Salesforce → HubSpot</span>
    <span class="tag">Pipedrive → HubSpot</span>
    <span class="tag">Excel / Sheets</span>
    <span class="tag" data-de="Datenmapping" data-en="Data Mapping">Datenmapping</span>
    <span class="tag" data-de="Deduplizierung" data-en="Deduplication">Deduplizierung</span>
    <span class="tag" data-de="Datenhygiene" data-en="Data Hygiene">Datenhygiene</span>
    <span class="tag" data-de="Validierung" data-en="Validation">Validierung</span>
    <span class="tag" data-de="Rollback-Plan" data-en="Rollback Plan">Rollback-Plan</span>
  </div>
</div>

<section class="block" id="leistung">
  <div class="wrap">
    <div class="head reveal">
      <p class="eyebrow" data-de="Was ich liefere" data-en="What I deliver">Was ich liefere</p>
      <h2 data-de="Migration ohne böse Überraschungen." data-en="Migration without nasty surprises.">Migration ohne böse Überraschungen.</h2>
    </div>
    <div class="work-grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr))">
      <div class="case reveal">
        <span class="ctag">01</span>
        <h3 data-de="Daten-Audit & Mapping" data-en="Data Audit & Mapping">Daten-Audit & Mapping</h3>
        <p data-de="Ich analysiere Ihre Quelldaten — Properties, Objekte, Relationen — und entwerfe das Zielmodell in HubSpot. Keine Überraschungen nach dem Import." data-en="I analyze your source data — properties, objects, relations — and design the target model in HubSpot. No surprises after the import.">Ich analysiere Ihre Quelldaten — Properties, Objekte, Relationen — und entwerfe das Zielmodell in HubSpot. Keine Überraschungen nach dem Import.</p>
      </div>
      <div class="case reveal">
        <span class="ctag">02</span>
        <h3 data-de="Bereinigung vor dem Import" data-en="Cleanup before import">Bereinigung vor dem Import</h3>
        <p data-de="Dubletten zusammenführen, veraltete Felder bereinigen, inkonsistente Werte normalisieren. Schmutzige Daten wandern nicht ins neue System." data-en="Merge duplicates, clean outdated fields, normalize inconsistent values. Dirty data doesn't travel to the new system.">Dubletten zusammenführen, veraltete Felder bereinigen, inkonsistente Werte normalisieren. Schmutzige Daten wandern nicht ins neue System.</p>
      </div>
      <div class="case reveal">
        <span class="ctag">03</span>
        <h3 data-de="Schrittweise Migration" data-en="Step-by-step migration">Schrittweise Migration</h3>
        <p data-de="Erst Staging, dann Validierung, dann Produktion. Mit Rollback-Option — damit ein Fehler keinen Betriebsausfall bedeutet." data-en="Staging first, then validation, then production. With a rollback option — so one error doesn't mean downtime.">Erst Staging, dann Validierung, dann Produktion. Mit Rollback-Option — damit ein Fehler keinen Betriebsausfall bedeutet.</p>
      </div>
      <div class="case reveal">
        <span class="ctag">04</span>
        <h3 data-de="Abnahme & Übergabe" data-en="Acceptance & handover">Abnahme & Übergabe</h3>
        <p data-de="Stichprobenprüfung, Vollständigkeitscheck, Dokumentation der Entscheidungen. Das Team übernimmt ein System, das es versteht." data-en="Sampling check, completeness review, documentation of decisions. The team takes over a system they understand.">Stichprobenprüfung, Vollständigkeitscheck, Dokumentation der Entscheidungen. Das Team übernimmt ein System, das es versteht.</p>
      </div>
    </div>
  </div>
</section>

<section class="block" style="border-top:1px solid var(--line)">
  <div class="wrap">
    <div class="head reveal">
      <p class="eyebrow" data-de="Typische Ausgangssituationen" data-en="Typical starting points">Typische Ausgangssituationen</p>
      <h2 data-de="Wann eine saubere Migration entscheidend ist." data-en="When a clean migration is critical.">Wann eine saubere Migration entscheidend ist.</h2>
    </div>
    <div class="ext-grid reveal">
      <div class="ext">
        <div class="ehead"><div class="glyph" aria-hidden="true">↗</div><h3 data-de="Wechsel von Salesforce oder Pipedrive" data-en="Moving from Salesforce or Pipedrive">Wechsel von Salesforce oder Pipedrive</h3></div>
        <p data-de="Historische Deals, Kontakte und Aktivitäten müssen strukturiert überführt werden — ohne Datenverlust und ohne Wochen manueller Nacharbeit." data-en="Historical deals, contacts, and activities need to be transferred in a structured way — without data loss and without weeks of manual cleanup.">Historische Deals, Kontakte und Aktivitäten müssen strukturiert überführt werden — ohne Datenverlust und ohne Wochen manueller Nacharbeit.</p>
      </div>
      <div class="ext">
        <div class="ehead"><div class="glyph" aria-hidden="true">⊞</div><h3 data-de="Merger & Konsolidierung" data-en="Merger & consolidation">Merger & Konsolidierung</h3></div>
        <p data-de="Mehrere CRM-Instanzen landen in einem Account. Das Datenmodell muss von Anfang an stimmen, damit das Reporting nicht sofort wieder lügt." data-en="Multiple CRM instances land in one account. The data model needs to be right from the start, so reporting doesn't immediately start lying.">Mehrere CRM-Instanzen landen in einem Account. Das Datenmodell muss von Anfang an stimmen, damit das Reporting nicht sofort wieder lügt.</p>
      </div>
      <div class="ext">
        <div class="ehead"><div class="glyph" aria-hidden="true">▦</div><h3 data-de="Excel / Sheets als „CRM"" data-en="Excel / Sheets as 'CRM'">Excel / Sheets als „CRM"</h3></div>
        <p data-de="Wenn das Unternehmen aus Spreadsheets herauswächst, ist der erste Import der wichtigste. Ich sorge dafür, dass er der letzte manuelle Export ist." data-en="When a company outgrows spreadsheets, the first import is the most important one. I make sure it's the last manual export.">Wenn das Unternehmen aus Spreadsheets herauswächst, ist der erste Import der wichtigste. Ich sorge dafür, dass er der letzte manuelle Export ist.</p>
      </div>
      <div class="ext">
        <div class="ehead"><div class="glyph" aria-hidden="true">◎</div><h3 data-de="HubSpot-Restrukturierung" data-en="HubSpot restructuring">HubSpot-Restrukturierung</h3></div>
        <p data-de="Manchmal ist das Ziel nicht ein neues System, sondern ein aufgeräumtes: Properties neu ordnen, Objekte konsolidieren, Altlasten löschen." data-en="Sometimes the goal isn't a new system but a clean one: reorganize properties, consolidate objects, delete legacy data.">Manchmal ist das Ziel nicht ein neues System, sondern ein aufgeräumtes: Properties neu ordnen, Objekte konsolidieren, Altlasten löschen.</p>
      </div>
    </div>
  </div>
</section>

<section class="block" style="border-top:1px solid var(--line)">
  <div class="wrap">
    <div class="head reveal">
      <p class="eyebrow" data-de="Weitere Leistungen" data-en="More services">Weitere Leistungen</p>
      <h2 data-de="Was ich sonst noch anbiete." data-en="What else I offer.">Was ich sonst noch anbiete.</h2>
    </div>
    <div class="work-grid" style="grid-template-columns:repeat(auto-fit,minmax(260px,1fr))">
      <a class="case" href="/leistungen/revops-fuer-startups" style="text-decoration:none;display:block">
        <span class="ctag">RevOps</span>
        <h3 data-de="RevOps für Startups" data-en="RevOps for Startups">RevOps für Startups</h3>
        <p data-de="Marketing, Sales und Service auf einer Datenbasis — für verlässliches Reporting und skalierbares Wachstum." data-en="Marketing, Sales and Service on one data foundation — for reliable reporting and scalable growth.">Marketing, Sales und Service auf einer Datenbasis — für verlässliches Reporting und skalierbares Wachstum.</p>
      </a>
      <a class="case" href="/leistungen/hubspot-fuer-b2b-saas" style="text-decoration:none;display:block">
        <span class="ctag">B2B SaaS</span>
        <h3 data-de="HubSpot für B2B-SaaS" data-en="HubSpot for B2B SaaS">HubSpot für B2B-SaaS</h3>
        <p data-de="PQL-Scoring, Trial-Flows, Churn-Signale — HubSpot als Wachstumsmotor für Software-Unternehmen." data-en="PQL scoring, trial flows, churn signals — HubSpot as a growth engine for software companies.">PQL-Scoring, Trial-Flows, Churn-Signale — HubSpot als Wachstumsmotor für Software-Unternehmen.</p>
      </a>
    </div>
  </div>
</section>

<section class="block contact" style="position:relative;border-top:1px solid var(--line)">
  <div class="wrap">
    <p class="eyebrow" data-de="Kontakt" data-en="Contact">Kontakt</p>
    <h2 data-de="Migrationsvorhaben besprechen?" data-en="Discuss a migration project?">Migrationsvorhaben besprechen?</h2>
    <p class="sub" data-de="Schildern Sie kurz, was migriert werden soll und woher die Daten kommen — dann schaue ich, wie viel Aufwand realistisch ist." data-en="Briefly describe what needs to be migrated and where the data comes from — then I'll assess how much effort is realistic.">Schildern Sie kurz, was migriert werden soll und woher die Daten kommen — dann schaue ich, wie viel Aufwand realistisch ist.</p>
    <div class="contact-actions">
      <a href="https://cal.com/mohammad-chakrouf-sp9k7e/hubspot-erstgesprach"
        class="btn btn-primary"
        target="_blank"
        rel="noopener"
        data-de="Termin buchen"
        data-en="Book a call"
        data-de-aria="Termin buchen (öffnet in neuem Tab)"
        data-en-aria="Book a call (opens in new tab)"
        aria-label="Termin buchen (öffnet in neuem Tab)">Termin buchen</a>
      <a href="mailto:chakroufmohammad@gmail.com" class="btn btn-ghost" data-de="E-Mail schreiben" data-en="Email me">E-Mail schreiben</a>
      <a href="https://www.linkedin.com/in/mohammad-chakrouf-ba2818208/"
        class="btn btn-ghost"
        target="_blank"
        rel="noopener"
        data-de-aria="LinkedIn (öffnet in neuem Tab)"
        data-en-aria="LinkedIn (opens in new tab)"
        aria-label="LinkedIn (öffnet in neuem Tab)">LinkedIn</a>
    </div>
  </div>
</section>

</Base>
