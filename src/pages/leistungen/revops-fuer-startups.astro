---
import Base from "../../layouts/Base.astro";
const serviceLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "RevOps für Startups",
  "description": "Revenue Operations für wachsende Startups: Marketing, Sales und Service auf einer Datenbasis für verlässliches Reporting und skalierbares Wachstum.",
  "provider": { "@id": "https://mohammad-chakrouf.de/#person" },
  "areaServed": [
    { "@type": "Country", "name": "Germany" },
    { "@type": "Country", "name": "Austria" },
    { "@type": "Country", "name": "Switzerland" }
  ],
  "serviceType": "Revenue Operations Consulting"
};
---
<Base
  title="RevOps für Startups — Mohammad Chakrouf, HubSpot Berater Berlin"
  titleEn="RevOps for Startups — Mohammad Chakrouf, HubSpot Consultant Berlin"
  description="Revenue Operations für wachsende Startups: Marketing, Sales und Service auf einer Datenbasis — für verlässliches Reporting und skalierbares Wachstum im DACH-Raum."
  descriptionEn="Revenue Operations for growing startups: Marketing, Sales and Service on one data foundation — for reliable reporting and scalable growth in the DACH region."
>
<script slot="head" type="application/ld+json" set:html={JSON.stringify(serviceLd)} />

<header class="hero" id="top">
  <div class="wrap">
    <p class="eyebrow"><span class="b" data-de="Leistung" data-en="Service">Leistung</span> · <span data-de="RevOps für Startups" data-en="RevOps for Startups">RevOps für Startups</span></p>
    <h1 style="font-family:var(--display);font-weight:900;font-size:clamp(2.4rem,5.5vw,4rem);line-height:1.05;letter-spacing:-.025em;max-width:16ch;margin:20px 0 22px" data-de="Marketing, Sales, Service — endlich eine Datenbasis." data-en="Marketing, Sales, Service — finally one data foundation.">Marketing, Sales, Service — endlich eine Datenbasis.</h1>
    <p class="sub" style="max-width:50ch" data-de="Ich baue die RevOps-Grundlage, damit Ihr Team aufhört, Zahlen aus drei verschiedenen Quellen zu ziehen — und anfängt, Entscheidungen auf verlässlichen Daten zu treffen." data-en="I build the RevOps foundation so your team stops pulling numbers from three different sources — and starts making decisions on data it can trust.">Ich baue die RevOps-Grundlage, damit Ihr Team aufhört, Zahlen aus drei verschiedenen Quellen zu ziehen — und anfängt, Entscheidungen auf verlässlichen Daten zu treffen.</p>
    <div class="hero-actions" style="margin-top:28px">
      <a href="/#contact" class="btn btn-primary" data-de="Gespräch anfragen" data-en="Request a call">Gespräch anfragen</a>
      <a href="/#about" class="btn btn-ghost" data-de="Über mich" data-en="About me">Über mich</a>
    </div>
  </div>
</header>

<div class="caps">
  <div class="wrap caps-in">
    <span class="tag" data-de="Lifecycle-Modell" data-en="Lifecycle model">Lifecycle-Modell</span>
    <span class="tag" data-de="Lead-Routing" data-en="Lead routing">Lead-Routing</span>
    <span class="tag" data-de="Pipeline-Design" data-en="Pipeline design">Pipeline-Design</span>
    <span class="tag">Attribution</span>
    <span class="tag" data-de="Reporting & Dashboards" data-en="Reporting &amp; dashboards">Reporting & Dashboards</span>
    <span class="tag" data-de="CRM-Hygiene" data-en="CRM hygiene">CRM-Hygiene</span>
    <span class="tag" data-de="GTM-Alignment" data-en="GTM alignment">GTM-Alignment</span>
    <span class="tag" data-de="Tool-Stack-Audit" data-en="Tool-stack audit">Tool-Stack-Audit</span>
  </div>
</div>

<section class="block" id="leistung">
  <div class="wrap">
    <div class="head reveal">
      <p class="eyebrow" data-de="Was RevOps konkret bedeutet" data-en="What RevOps actually means">Was RevOps konkret bedeutet</p>
      <h2 data-de="Kein Konzept. Eine funktionierende Grundlage." data-en="Not a concept. A working foundation.">Kein Konzept. Eine funktionierende Grundlage.</h2>
    </div>
    <div class="work-grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr))">
      <div class="case reveal">
        <span class="ctag">Unified Data Model</span>
        <h3 data-de="Ein Objektmodell für alle Teams" data-en="One object model for every team">Ein Objekt­modell für alle Teams</h3>
        <p data-de="Contact, Company, Deal, Ticket — klar definiert, einheitlich befüllt. Kein Property-Wildwuchs, keine manuellen Übergaben zwischen Abteilungen." data-en="Contact, Company, Deal, Ticket — clearly defined, consistently filled. No property sprawl, no manual handoffs between departments.">Contact, Company, Deal, Ticket — klar definiert, einheitlich befüllt. Kein Property-Wildwuchs, keine manuellen Übergaben zwischen Abteilungen.</p>
      </div>
      <div class="case reveal">
        <span class="ctag">Lifecycle & Pipeline</span>
        <h3 data-de="Lifecycle-Stages, die sich selbst pflegen" data-en="Lifecycle stages that maintain themselves">Lifecycle-Stages, die sich selbst pflegen</h3>
        <p data-de="Automatische Stage-Wechsel auf Basis klarer Kriterien — statt manueller Disziplin, die nach drei Wochen zusammenbricht." data-en="Automatic stage changes based on clear criteria — instead of manual discipline that collapses after three weeks.">Automatische Stage-Wechsel auf Basis klarer Kriterien — statt manueller Disziplin, die nach drei Wochen zusammenbricht.</p>
      </div>
      <div class="case reveal">
        <span class="ctag">Reporting</span>
        <h3 data-de="Dashboards, denen das Team traut" data-en="Dashboards the team trusts">Dashboards, denen das Team traut</h3>
        <p data-de="MQL, SQL, Win-Rate, Churn — auf einer Quelle, nicht aus drei Sheets. Ich baue Dashboards, die Ihr Team täglich nutzt." data-en="MQL, SQL, win rate, churn — from one source, not three sheets. I build dashboards your team uses every day.">MQL, SQL, Win-Rate, Churn — auf einer Quelle, nicht aus drei Sheets. Ich baue Dashboards, die Ihr Team täglich nutzt.</p>
      </div>
      <div class="case reveal">
        <span class="ctag">Prozess-Design</span>
        <h3 data-de="Lead-Routing und Handoff-Logik" data-en="Lead routing and handoff logic">Lead-Routing und Handoff-Logik</h3>
        <p data-de="Wann ein Lead von Marketing an Sales übergeht, wie Deals eskaliert werden, wie CS informiert wird — als verlässliche Automation, nicht als E-Mail-Kette." data-en="When a lead moves from Marketing to Sales, how deals escalate, how CS gets notified — as reliable automation, not an email chain.">Wann ein Lead von Marketing an Sales übergeht, wie Deals eskaliert werden, wie CS informiert wird — als verlässliche Automation, nicht als E-Mail-Kette.</p>
      </div>
    </div>
  </div>
</section>

<section class="block" style="border-top:1px solid var(--line)">
  <div class="wrap">
    <div class="head reveal">
      <p class="eyebrow" data-de="Wie ich vorgehe" data-en="How I work">Wie ich vorgehe</p>
      <h2 data-de="Von der Diagnose zur laufenden Grundlage." data-en="From diagnosis to a running foundation.">Von der Diagnose zur laufenden Grundlage.</h2>
    </div>
    <div class="pipe reveal">
      <div class="stage">
        <div class="num">01</div>
        <h3 data-de="GTM-Audit" data-en="GTM audit">GTM-Audit</h3>
        <p data-de="Wie arbeiten Marketing, Sales und Service heute zusammen? Wo entstehen Reibungen, Datenverluste, blinde Flecken im Funnel?" data-en="How do Marketing, Sales and Service work together today? Where do friction, data loss and blind spots in the funnel come from?">Wie arbeiten Marketing, Sales und Service heute zusammen? Wo entstehen Reibungen, Datenverluste, blinde Flecken im Funnel?</p>
      </div>
      <div class="stage">
        <div class="num">02</div>
        <h3 data-de="Modell-Design" data-en="Model design">Modell-Design</h3>
        <p data-de="Objekte, Properties, Lifecycle-Stages und Pipelines so entwerfen, dass sie die realen Prozesse widerspiegeln — und skalieren." data-en="Designing objects, properties, lifecycle stages and pipelines so they mirror your real processes — and scale.">Objekte, Properties, Lifecycle-Stages und Pipelines so entwerfen, dass sie die realen Prozesse widerspiegeln — und skalieren.</p>
      </div>
      <div class="stage">
        <div class="num">03</div>
        <h3 data-de="Implementation" data-en="Implementation">Implementation</h3>
        <p data-de="Setup in HubSpot: Workflows, Scoring, Routing, Dashboards. Schritt für Schritt, mit dem Team, nicht am Team vorbei." data-en="Setup in HubSpot: workflows, scoring, routing, dashboards. Step by step, with the team, not over their heads.">Setup in HubSpot: Workflows, Scoring, Routing, Dashboards. Schritt für Schritt, mit dem Team, nicht am Team vorbei.</p>
      </div>
      <div class="stage">
        <div class="num">04</div>
        <h3 data-de="Übergabe" data-en="Handover">Übergabe</h3>
        <p data-de="Dokumentation, Schulung, klare Owner. Das Ziel ist Unabhängigkeit — kein dauerhafter Consultant-Lock-in." data-en="Documentation, training, clear owners. The goal is independence — no permanent consultant lock-in.">Dokumentation, Schulung, klare Owner. Das Ziel ist Unabhängigkeit — kein dauerhafter Consultant-Lock-in.</p>
      </div>
    </div>
  </div>
</section>

<section class="block" style="border-top:1px solid var(--line)">
  <div class="wrap">
    <div class="head reveal">
      <p class="eyebrow" data-de="Weitere Leistungen" data-en="More services">Weitere Leistungen</p>
      <h2 data-de="Was ich sonst noch anbiete." data-en="What else I offer.">Was ich sonst noch anbiete.</h2>
    </div>
    <div class="work-grid" style="grid-template-columns:repeat(auto-fit,minmax(260px,1fr))">
      <a class="case" href="/leistungen/hubspot-migration" style="text-decoration:none;display:block">
        <span class="ctag">Migration</span>
        <h3 data-de="HubSpot-Migration" data-en="HubSpot Migration">HubSpot-Migration</h3>
        <p data-de="Von Salesforce, Pipedrive oder Excel zu HubSpot — strukturiert, bereinigt, ohne Betriebsunterbrechung." data-en="From Salesforce, Pipedrive or Excel to HubSpot — structured, cleaned, without disrupting operations.">Von Salesforce, Pipedrive oder Excel zu HubSpot — strukturiert, bereinigt, ohne Betriebsunterbrechung.</p>
      </a>
      <a class="case" href="/leistungen/hubspot-fuer-b2b-saas" style="text-decoration:none;display:block">
        <span class="ctag">B2B SaaS</span>
        <h3 data-de="HubSpot für B2B-SaaS" data-en="HubSpot for B2B SaaS">HubSpot für B2B-SaaS</h3>
        <p data-de="PQL-Scoring, Trial-Flows, Churn-Signale — HubSpot als Wachstumsmotor für Software-Unternehmen." data-en="PQL scoring, trial flows, churn signals — HubSpot as a growth engine for software companies.">PQL-Scoring, Trial-Flows, Churn-Signale — HubSpot als Wachstumsmotor für Software-Unternehmen.</p>
      </a>
    </div>
  </div>
</section>

<section class="block contact" style="position:relative;border-top:1px solid var(--line)">
  <div class="wrap">
    <p class="eyebrow" data-de="Kontakt" data-en="Contact">Kontakt</p>
    <h2 data-de="RevOps-Thema im Startup?" data-en="A RevOps challenge at your startup?">RevOps-Thema im Startup?</h2>
    <p class="sub" data-de="Schildern Sie, wo es bei Ihnen hakt — Reporting, Handoffs, Pipeline-Qualität — und ich sage Ihnen, wie wir das strukturieren können." data-en="Tell me where things are stuck — reporting, handoffs, pipeline quality — and I'll tell you how we can structure it.">Schildern Sie, wo es bei Ihnen hakt — Reporting, Handoffs, Pipeline-Qualität — und ich sage Ihnen, wie wir das strukturieren können.</p>
    <div class="contact-actions">
      <a href="https://cal.com/mohammad-chakrouf-sp9k7e/hubspot-erstgesprach"
        class="btn btn-primary"
        target="_blank"
        rel="noopener"
        data-de="Termin buchen"
        data-en="Book a call"
        data-de-aria="Termin buchen (öffnet in neuem Tab)"
        data-en-aria="Book a call (opens in new tab)"
        aria-label="Termin buchen (öffnet in neuem Tab)">Termin buchen</a>
      <a href="mailto:chakroufmohammad@gmail.com" class="btn btn-ghost" data-de="E-Mail schreiben" data-en="Email me">E-Mail schreiben</a>
      <a href="https://www.linkedin.com/in/mohammad-chakrouf-ba2818208/"
        class="btn btn-ghost"
        target="_blank"
        rel="noopener"
        data-de-aria="LinkedIn (öffnet in neuem Tab)"
        data-en-aria="LinkedIn (opens in new tab)"
        aria-label="LinkedIn (öffnet in neuem Tab)">LinkedIn</a>
    </div>
  </div>
</section>

</Base>
